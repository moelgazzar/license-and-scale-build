# Supabase - persistent business data only (NEVER store API keys here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI - real LLM call for draft generation + reply classification
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# fallback used automatically if the configured model is not available: gpt-4o-mini

# Telegram Bot API - external integration
# Internal approval pings on draft approve + alerts on hot replies
# Create a bot via @BotFather, then add it to a chat or group and grab the chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: GHL adapter (DISABLED in this demo due to A2P compliance and credential turnaround)
# Production wires the outbox dispatch to GHL or Twilio behind this flag.
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_SEND_ENABLED=false
